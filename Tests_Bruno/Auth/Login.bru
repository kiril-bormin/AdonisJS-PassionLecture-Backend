meta {
  name: Auth_Login
  type: http
  seq: 2
}

post {
  url: http://localhost:3333/api/auth/login
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
  "email": "bruno_user@example.com",
  "password": "Password123!"
  }
}

script:post-response {
  const data = res.getBody();
  
  // On descend d'un niveau pour ne prendre QUE la chaîne de caractères
  if (data.token && data.token.token) {
    bru.setVar("api_token", data.token.token);
  }
}
