meta {
  name: Books_Create
  type: http
  seq: 53
}

post {
  url: http://localhost:3333/api/books
  body: json
  auth: bearer
}

headers {
  Authorization: Bearer YOUR_TOKEN
  Content-Type: application/json
}

auth:bearer {
  token: {{api_token}}
}

body:json {
  {
  "title": "Voyage au centre de la Terre",
  "categoryId": 1,
  "authorId": 1,
  "publisherId": 1,
  "pages": 240,
  "excerptUrl": "/extraits/voyage-centre-terre.pdf",
  "summary": "Un classique de la science-fiction.",
  "coverUrl": "/covers/voyage-centre-terre.jpg",
  "year": 1864
  }
}

script:post-response {
  const data = res.getBody();
  
  // On descend d'un niveau pour ne prendre QUE la chaîne de caractères
  if (data.token && data.token.token) {
    bru.setVar("api_token", data.token.token);
  }
}
