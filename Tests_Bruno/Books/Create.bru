meta {
  name: Books_Create
  type: http
  seq: 53
}

post {
  url: {{baseUrl}}/books
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  "title": "Voyage au centre de la Terre",
  "categoryId": "{{categoryId}}",
  "authorId": "{{authorId}}",
  "publisherId": "{{publisherId}}",
  "pages": 240,
  "excerptUrl": "/extraits/voyage-centre-terre.pdf",
  "summary": "Un classique de la science-fiction.",
  "coverUrl": "/covers/voyage-centre-terre.jpg",
  "year": 1864
}

